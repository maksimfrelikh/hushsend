# ============================================================================
# hushsend signaling server — environment template
# ============================================================================
# Every env var the signaling server reads, with its default and WHEN to change
# it. Copy to server/.env (or set these in your process manager's unit/ecosystem
# file) and edit. The server is UNTRUSTED by design — these knobs are transport
# plumbing + abuse hygiene, NOT authentication (SAS / key-confirmation defeat a
# MITM regardless). Nothing here is read by the browser; client build-time env
# (VITE_*) lives in the repo root — see CLAUDE.md § Deployment / configuration.
#
# The startup log prints a one-line [config] summary of the effective values
# (no secrets) — confirm it matches this file after each restart.
# ----------------------------------------------------------------------------

# --- Bind / transport --------------------------------------------------------
# Loopback ONLY behind nginx — the local proxy is the sole thing that reaches
# Node, so nobody external can inject a fake X-Real-IP by bypassing the proxy.
HOST=127.0.0.1
# Port nginx proxies `location /ws` (and /health) to. Match the nginx upstream.
PORT=8080

# --- Proxy / client-IP (CRITICAL behind nginx) -------------------------------
# MUST be 1 in production behind nginx. clientIp() then trusts ONLY X-Real-IP
# (set by nginx), never the client-controllable X-Forwarded-For. If left 0 (or
# nginx doesn't set X-Real-IP), every client looks like loopback 127.0.0.1 →
# the per-IP caps collapse onto ONE bucket and the 4011 attempt rate-limit
# silently disables (loopback is exempt). See deploy/nginx.conf.example /ws.
TRUST_PROXY=1
# Reverse-proxy hops you operate (nginx = 1). Only used to pick the right
# X-Forwarded-For entry when X-Real-IP is absent; leave at 1 for a single nginx.
TRUSTED_PROXY_HOPS=1

# --- TURN relay (Reliable mode) ----------------------------------------------
# Short-lived coturn credentials are minted on a `turn-request` frame
# (use-auth-secret / REST scheme). The secret is SHARED with coturn's
# `static-auth-secret` (deploy/coturn.conf.example) and lives ONLY here — it is
# NEVER sent to the browser, only a derived per-session username+credential.
# LEAVE EMPTY to disable relay → the server answers with empty urls and clients
# stay direct-only (= Max-privacy everywhere). Set it (== coturn's secret) to
# enable Reliable-mode fallback.
TURN_SECRET=
# Comma-separated turn:/turns: URIs handed to clients (the coturn host, NOT a
# secret). Empty ⇒ relay treated as unavailable even if TURN_SECRET is set.
# e.g. TURN_URLS=turn:turn.hushsend.frelikh.dev:3478,turns:turn.hushsend.frelikh.dev:5349
TURN_URLS=
# Credential lifetime in seconds (the username embeds a future unix-expiry that
# coturn enforces offline). 1h is plenty for a transfer to start.
TURN_CRED_TTL_S=3600

# --- Resource caps (anti-DoS; tune per host/traffic) -------------------------
# These COMPLEMENT, not replace, OS/proxy limits. Defaults shown.
MAX_CONNS_TOTAL=5000          # server-wide live socket ceiling
MAX_CONNS_PER_IP=20           # live sockets per client IP (needs X-Real-IP to be per-client!)
# Per-IP-per-room cap. DEFAULT (unset / 0) = the room's OWN seat cap, so one IP may fill a room up to
# the room cap and the ROOM CAP is the binding per-room limit. This is intentional: a co-located group
# (meeting/class/office behind one NAT = one shared public IP) is exactly the audience the lobby cap
# (FILETRANSFER_MAX_PEERS) exists for, and a hardcoded small cap would wrongly block it. Set a value
# BELOW the room cap to RE-tighten per-room anti-domination (one IP then can't fill a room) at the cost
# of co-located groups not gathering past that value. (Global per-IP limits stay: MAX_CONNS_PER_IP +
# IP_RL_MAX.)
# MAX_PER_IP_PER_ROOM=        # unset ⇒ room cap; e.g. =2 to cap one IP at 2 seats per room
MAX_ROOMS=2000                # concurrent rooms ceiling
FILETRANSFER_MAX_PEERS=8      # 4-digit ROOM LOBBY size = also the default per-IP-per-room cap (words/link/QR token are always 1:1)

# --- TTL until connected (frees the rendezvous code; live P2P survives it) ---
ROOM_TTL_MS=180000            # 4-digit ROOM — IDLE timeout, re-armed on each join (~3 min)
WORD_ROOM_TTL_MS=180000       # words rendezvous — armed at CREATE, never re-armed (bounds guessing)
TOKEN_ROOM_TTL_MS=180000      # link/QR token rendezvous — armed at CREATE, never re-armed (1:1, natural pre-connect wait)

# --- Per-IP create/join attempt rate-limit (managed app; loopback-exempt) ----
# Fixed window; slows enumeration/squatting of the small 4-digit code space.
# SHARED-NAT NOTE: clients behind one public IP (office/CGNAT) DIVIDE this budget
# among everyone → a busy network can hit a spurious 4011. Raise IP_RL_MAX for
# such deploys; it's defense-in-depth only (worst case is a retry — SAS is what
# actually stops a MITM). See BACKLOG.md § Deployment behind nginx (6f) and
# CLAUDE.md § Deployment / configuration for the X-Real-IP / shared-NAT notes.
IP_RL_MAX=60                  # create/join attempts per window per remote IP
IP_RL_WINDOW_MS=60000         # window length (~1 min)

# --- Per-socket message rate-limit (relay-flood / parse-CPU guard) -----------
MSG_WINDOW_MS=10000           # rolling window for the two limits below
MSG_SOFT_LIMIT=100            # over → drop (don't relay) the frame
MSG_HARD_LIMIT=300            # over → close the socket (4008) as a clear flood

# --- Misc --------------------------------------------------------------------
# PING_MS=30000               # WS heartbeat interval (keep nginx proxy_read_timeout WELL above it)
# MAX_PAYLOAD=65536           # max WS frame bytes (SDP/ICE are small; 64KB is plenty)
# NODE_ENV=production         # set by your process manager; gates dev-only localhost origins
